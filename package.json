{
  "name": "loud-talker",
  "version": "0.1.0",
  "description": "Visual feedback to keep your voice volume in check on calls.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp src/renderer/*.html src/renderer/*.css dist/renderer/",
    "start": "npm run build && electron .",
    "dev": "npm run start"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.9.0",
    "electron": "^33.2.0",
    "typescript": "^5.6.3"
  }
}
