{
  "name": "loud-talker",
  "version": "0.1.0",
  "description": "Visual feedback to keep your voice volume in check on calls.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run copy-assets && npm run bundle-renderer",
    "copy-assets": "cp src/renderer/*.html src/renderer/*.css dist/renderer/",
    "bundle-renderer": "esbuild src/renderer/main_renderer.ts --bundle --outfile=dist/renderer/main_renderer.js --platform=browser --format=iife",
    "start": "npm run build && electron .",
    "dev": "npm run start",
    "package": "npm run build && electron-builder --mac --publish=never",
    "package:dir": "npm run build && electron-builder --mac --dir --publish=never",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.shawnburke.loud-talker",
    "productName": "Loud Talker",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Loud Talker needs microphone access to monitor your speaking volume."
      }
    }
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.9.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
