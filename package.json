{
  "name": "loud-talker",
  "version": "0.1.0",
  "description": "Visual feedback to keep your voice volume in check on calls.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp src/renderer/*.html src/renderer/*.css dist/renderer/",
    "start": "npm run build && electron .",
    "dev": "npm run start",
    "package": "npm run build && electron-builder --mac",
    "package:dir": "npm run build && electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.shawnburke.loud-talker",
    "productName": "Loud Talker",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.9.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.6.3"
  }
}
